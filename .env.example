# PullSage process
PULLSAGE_ENV=development
PULLSAGE_HOST=127.0.0.1
PULLSAGE_PORT=8000
PULLSAGE_LOG_LEVEL=INFO

# GitHub REST API and webhook authentication
# Use a fine-grained token with read access to pull requests and contents.
# Add pull-request write access only when review posting is intentionally enabled.
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_API_URL=https://api.github.com

# Local Codex CLI
CODEX_COMMAND=codex
# Leave empty to use the model configured by the Codex user.
CODEX_MODEL=
CODEX_TIMEOUT_SECONDS=300

# Write safety: both controls are disabled by default.
PULLSAGE_POST_COMMENTS=false
PULLSAGE_ALLOW_MCP_WRITE_TOOLS=false

# Review bounds and worker limits
PULLSAGE_MIN_CONFIDENCE=0.80
PULLSAGE_MAX_DIFF_CHARS=200000
PULLSAGE_MAX_CHANGED_FILES=100
PULLSAGE_MAX_CONCURRENT_REVIEWS=2
PULLSAGE_JOB_RETENTION_SECONDS=3600

# Webhook delivery de-duplication cache
PULLSAGE_DELIVERY_RETENTION_SECONDS=3600
PULLSAGE_MAX_WEBHOOK_DELIVERIES=10000
